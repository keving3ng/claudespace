# Discord Bridge — copy this to .env and fill in your values

# Bot token from Discord Developer Portal → Your App → Bot → Token
DISCORD_BOT_TOKEN=your_bot_token_here

# Channel ID where Kevin talks to Claude (right-click channel → Copy ID)
DISCORD_CHANNEL_ID=your_channel_id_here

# Webhook URL for Claude → Discord posts (Channel Settings → Integrations → Webhooks)
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/your_webhook_url_here

# Your Discord user ID (right-click your name → Copy ID)
DISCORD_KEVIN_USER_ID=your_user_id_here

# Absolute path to your claudespace repo
CLAUDESPACE_ROOT=/Users/kevingeng/code/claudespace
