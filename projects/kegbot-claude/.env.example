# kegbot-claude environment variables
# Copy to .env and fill in your values

# Required: your Anthropic API key
ANTHROPIC_API_KEY=sk-ant-...

# Optional: GitHub personal access token (raises rate limit from 60 to 5000 req/hr)
# Get one at: https://github.com/settings/tokens (no scopes needed for public repos)
GITHUB_TOKEN=

# Optional: override the default GitHub username to fetch activity for
GITHUB_USERNAME=keving3ng
